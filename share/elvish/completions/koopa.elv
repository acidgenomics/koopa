# Koopa elvish completions.
# @note Updated 2026-05-09.
# @note Auto-generated by 'koopa develop generate-completion'.

use str

set edit:completion:arg-completer[koopa] = {|@args|
    var n = (count $args)
    var last = $args[-1]

    # Flag completions.
    if (str:has-prefix $last '--') {
        var path = ''
        if (>= $n 3) {
            set path = $args[1]
        }
        if (>= $n 4) {
            set path = $path'/'$args[2]
        }
        if (>= $n 5) {
            set path = $path'/'$args[3]
        }
        if (eq $path 'admin') {
            put --help
        } elif (eq $path 'app') {
            put --help
        } elif (eq $path 'app/aws/batch/fetch-and-run') {
            put --help --job-definition --job-name --memory --profile --queue --vcpus
        } elif (eq $path 'app/aws/batch/list-jobs') {
            put --help --profile --queue --status
        } elif (eq $path 'app/aws/ec2/list-running-instances') {
            put --help --profile
        } elif (eq $path 'app/aws/ec2/map-instance-ids-to-names') {
            put --help --profile
        } elif (eq $path 'app/aws/ec2/stop') {
            put --help --profile
        } elif (eq $path 'app/aws/ecr/login-private') {
            put --account-id --help --profile --region
        } elif (eq $path 'app/aws/ecr/login-public') {
            put --help --region
        } elif (eq $path 'app/aws/s3/delete-versioned-glacier-objects') {
            put --bucket --help --prefix --profile
        } elif (eq $path 'app/aws/s3/delete-versioned-objects') {
            put --bucket --help --prefix --profile
        } elif (eq $path 'app/aws/s3/dot-clean') {
            put --dryrun --help --profile
        } elif (eq $path 'app/aws/s3/find') {
            put --bucket --help --pattern --prefix --profile
        } elif (eq $path 'app/aws/s3/list-large-files') {
            put --bucket --help --min-size-mb --prefix --profile
        } elif (eq $path 'app/aws/s3/ls') {
            put --help --profile --recursive
        } elif (eq $path 'app/aws/s3/mv-to-parent') {
            put --dryrun --help --profile
        } elif (eq $path 'app/aws/s3/sync') {
            put --delete --dryrun --exclude --help --include --profile
        } elif (eq $path 'app/aws/s3/sync-git-repo') {
            put --delete --dryrun --help --profile
        } elif (eq $path 'app/bowtie2/align/paired-end') {
            put --fastq-dir --help --index-dir --output-dir --output-format --reference-fasta
        } elif (eq $path 'app/bowtie2/index') {
            put --genome-fasta-file --help --output-dir
        } elif (eq $path 'app/conda/create-env') {
            put --file --force --help --latest --prefix
        } elif (eq $path 'app/docker/build') {
            put --help --local --memory --no-push --remote
        } elif (eq $path 'app/docker/build-all-tags') {
            put --help --local --remote
        } elif (eq $path 'app/docker/run') {
            put --arm --bash --bind --help --x86
        } elif (eq $path 'app/file/compress') {
            put --help --output
        } elif (eq $path 'app/ftp/mirror') {
            put --dir --help --host --user
        } elif (eq $path 'app/hisat2/align/paired-end') {
            put --fastq-dir --gtf-file --help --index-dir --output-dir
        } elif (eq $path 'app/hisat2/align/single-end') {
            put --fastq-dir --gtf-file --help --index-dir --output-dir
        } elif (eq $path 'app/hisat2/index') {
            put --genome-fasta-file --gtf-file --help --output-dir
        } elif (eq $path 'app/jekyll/deploy-to-aws') {
            put --bucket --distribution-id --help --local-prefix --profile
        } elif (eq $path 'app/kallisto/index') {
            put --help --output-dir --transcriptome-fasta-file
        } elif (eq $path 'app/kallisto/quant/paired-end') {
            put --fastq-dir --help --index-dir --output-dir
        } elif (eq $path 'app/kallisto/quant/single-end') {
            put --fastq-dir --help --index-dir --output-dir
        } elif (eq $path 'app/miso/index') {
            put --gff-file --help --output-dir
        } elif (eq $path 'app/r/shiny-run-app') {
            put --help --port
        } elif (eq $path 'app/rnaeditingindexer') {
            put --bam-dir --example --genome --help --output-dir
        } elif (eq $path 'app/rsem/index') {
            put --genome-fasta-file --gtf-file --help --num-threads --output-dir
        } elif (eq $path 'app/rsem/quant/bam') {
            put --bam-file --help --index-dir --output-dir
        } elif (eq $path 'app/salmon/detect-fastq-library-type') {
            put --help --index-dir --r1 --r2 --threads
        } elif (eq $path 'app/salmon/index') {
            put --help --output-dir --transcriptome-fasta-file
        } elif (eq $path 'app/salmon/quant/bam') {
            put --fastq-dir --help --index-dir --output-dir
        } elif (eq $path 'app/salmon/quant/paired-end') {
            put --fastq-dir --help --index-dir --output-dir
        } elif (eq $path 'app/salmon/quant/single-end') {
            put --fastq-dir --help --index-dir --output-dir
        } elif (eq $path 'app/sra/download-accession-list') {
            put --file --help --srp-id
        } elif (eq $path 'app/sra/download-run-info-table') {
            put --file --help --srp-id
        } elif (eq $path 'app/sra/fastq-dump') {
            put --fastq-directory --help --no-compress --prefetch-directory
        } elif (eq $path 'app/sra/prefetch') {
            put --accession-file --help --output-dir
        } elif (eq $path 'app/ssh/generate-key') {
            put --help --prefix
        } elif (eq $path 'app/star/align/paired-end') {
            put --fastq-dir --gtf-file --help --index-dir --output-dir
        } elif (eq $path 'app/star/align/single-end') {
            put --fastq-dir --gtf-file --help --index-dir --output-dir
        } elif (eq $path 'app/star/index') {
            put --genome-fasta-file --gtf-file --help --output-dir
        } elif (eq $path 'app/wget/recursive') {
            put --help --password --url --user
        } elif (eq $path 'configure') {
            put --help --verbose
        } elif (eq $path 'develop') {
            put --help
        } elif (eq $path 'develop/check-app-versions') {
            put --help --json --no-update --reset-cache --s3-upload --source
        } elif (eq $path 'develop/format-app-json') {
            put --help --prettier
        } elif (eq $path 'develop/remove-app') {
            put --help --revdeps
        } elif (eq $path 'install') {
            put --all --help --no-dependencies --reinstall --verbose
        } elif (eq $path 'list') {
            put --all --help
        } elif (eq $path 'reinstall') {
            put --all --all-revdeps --help --no-revdeps --only-revdeps --verbose
        } elif (eq $path 'run') {
            put --help
        } elif (eq $path 'system') {
            put --help
        } elif (eq $path 'uninstall') {
            put --help --no-revdeps --non-default --verbose --yes
        } elif (eq $path 'update') {
            put --help --verbose
        }
    } elif (== $n 2) {
        # Top-level subcommands.
        put --help --version admin app configure develop install list reinstall run system uninstall update
    } elif (== $n 3) {
        # Depth 1: subcommands of top-level.
        if (eq $args[1] 'app') {
            put aws bioconda bowtie2 brew conda current docker file ftp git gpg hisat2 jekyll kallisto md5sum miso photos r rnaeditingindexer rsem salmon sra ssh star sys wget
        } elif (eq $args[1] 'develop') {
            put app-deps app-revdeps audit-src-mirror bump-bootstrap bump-revision bump-venv-version cache-functions check-app-versions circular-dependencies conda-candidates edit-app-json find-ignored-bin-files format-app-json generate-completion generate-man log mirror-src orphan-apps prune-app-binaries push-all-app-builds push-app-build push-app-builds pyright pytest remove-app reset-revisions shellcheck update-docs
        } elif (eq $args[1] 'run') {
            put autopad-zeros clone convert-svg-to-png convert-utf8-nfd-to-nfc create-dmg delete-broken-symlinks delete-empty-dirs delete-named-subdirs detab df2 dot-clean download download-cran-latest download-github-latest entab eol-lf extract extract-all file-count find-and-move-in-sequence find-and-replace find-broken-symlinks find-empty-dirs find-files-without-line-ending find-large-dirs find-large-files ifactive ip-address ip-info line-count merge-pdf move-files-in-batch move-files-up-1-level move-into-dated-dirs-by-filename move-into-dated-dirs-by-timestamp nfiletypes rename-camel-case rename-from-csv rename-kebab-case rename-lowercase rename-snake-case rg-sort rg-unique sort-lines spotlight tar-multiple-dirs
        } elif (eq $args[1] 'system') {
            put check hostname info list os-slug prefix prune-apps switch-to-develop version which
        } elif (eq $args[1] 'admin') {
            put add-group add-user apk-install apk-remove apk-update apt-install apt-list-installed apt-remove apt-update apt-upgrade clean-launch-services configure-lmod configure-sshd delete-cache delete-user disable-passwordless-sudo disable-touch-id-sudo dnf-install dnf-remove dnf-update enable-passwordless-sudo enable-touch-id-sudo fix-sudo-setrlimit-error flush-dns force-eject install-app os-version pacman-install pacman-remove pacman-update proc-cmdline reload-autofs systemctl-disable systemctl-restart systemctl-status systemctl-stop uninstall-app zsh-compaudit-set-permissions zypper-install zypper-remove zypper-update
        } elif (eq $args[1] 'install') {
            put ack agat air anaconda apache-airflow apache-arrow apache-spark apptainer apr apr-util aria2 armadillo asdf aspell aspera-connect attr autoconf autodock autodock-adfr autodock-vina autoflake automake aws-azure-login aws-cli aws-mountpoint-s3 axel azure-cli bamtools bandit bandwhich bash bash-completion bash-language-server bashcov bat bc bcbio-nextgen bcl2fastq bedtk bedtools bfg binutils bioawk bioconda-utils bison black blast boost bottom bowtie2 bpytop broot brotli btop bumpver bustools byobu bzip2 c-ares ca-certificates cairo cellranger cereal cheat chemacs chezmoi claude-code cli11 cloudbiolinux cmake colorls commitizen conda convmv coreutils cpufetch csvkit csvtk curl dash databricks-cli deeptools delta diff-so-fancy difftastic direnv docker-credential-helpers doom-emacs dotfiles du-dust duckdb ed editorconfig elfutils elvish emacs ensembl-perl-api entrez-direct exa exiftool expat eza fastqc fd-find ffmpeg ffq fgbio findutils fish flac flake8 flex fltk fmt fontconfig fq fqtk freetype fribidi fzf gatk gawk gcc gdal gdbm gdc-client gemini-cli genomepy gentropy geos gettext gffutils gget gh ghostscript git git-filter-repo git-lfs gitui glances glib gmp gnupg gnutls go google-cloud-sdk googletest gperf graphviz grep grex groff gseapy gsl gtop gum gzip hadolint harfbuzz haskell-cabal haskell-ghcup haskell-stack hdf5 hexyl hisat2 htop htseq htslib httpie httpx huggingface-hub hugo hyperfine icu4c illumina-ica-cli imagemagick ipython isl isort jemalloc jfrog-cli jless jpeg jq julia jupyterlab k9s kallisto krb5 ksh93 lame lapack latch ldc ldns less lesspipe libaec libarchive libassuan libcbor libconfig libde265 libdeflate libedit libev libevent libffi libfido2 libgcrypt libgeotiff libgit2 libgpg-error libheif libiconv libidn libjpeg-turbo libksba liblinear libluv libpcap libpipeline libpng libsolv libssh2 libtasn1 libtermkey libtiff libtool libunistring libuv libvterm libxcrypt libxml2 libxslt libyaml libzip llama llvm lmod lsd lua luajit luarocks luigi