        } elif (eq $args[1] 'update') {
            put koopa system user
        } elif (eq $args[1] 'configure') {
            put system user
        }
    } elif (== $n 4) {
        # Depth 2: app namespace subcommands.
        if (eq $args[1] 'app') {
            if (eq $args[2] 'aws') {
                put batch ec2 ecr s3
            } elif (eq $args[2] 'bioconda') {
                put autobump-recipe
            } elif (eq $args[2] 'bowtie2') {
                put align index
            } elif (eq $args[2] 'brew') {
                put cleanup dump-brewfile outdated reset-core-repo reset-permissions uninstall-all-brews upgrade-brews version
            } elif (eq $args[2] 'conda') {
                put clean-cache create-env remove-env
            } elif (eq $args[2] 'current') {
                put aws-cli-version bioconductor-version conda-package-version ensembl-version flybase-version gencode-version git-version github-release-version github-tag-version gnu-ftp-version google-cloud-sdk-version latch-version pypi-package-version python-version refseq-version wormbase-version
            } elif (eq $args[2] 'docker') {
                put build build-all-tags prune-all-images prune-old-images remove run
            } elif (eq $args[2] 'file') {
                put compress convert-line-endings rename-to-lowercase-ext
            } elif (eq $args[2] 'ftp') {
                put mirror
            } elif (eq $args[2] 'git') {
                put pull push-submodules rename-master-to-main reset reset-fork-to-upstream rm-submodule rm-untracked
            } elif (eq $args[2] 'gpg') {
                put prompt reload restart
            } elif (eq $args[2] 'hisat2') {
                put align index
            } elif (eq $args[2] 'jekyll') {
                put deploy-to-aws serve
            } elif (eq $args[2] 'kallisto') {
                put index quant
            } elif (eq $args[2] 'md5sum') {
                put check-to-new-md5-file
            } elif (eq $args[2] 'miso') {
                put index
            } elif (eq $args[2] 'photos') {
                put rename-with-exiftool
            } elif (eq $args[2] 'r') {
                put bioconda-check check configure-environ configure-java configure-ldpaths configure-makevars copy-files-into-etc gfortran-libs install-packages-in-site-library migrate-non-base-packages package-version paste-to-vector remove-packages-in-system-library script shiny-run-app system-packages-non-base version
            } elif (eq $args[2] 'rsem') {
                put index quant
            } elif (eq $args[2] 'salmon') {
                put detect-fastq-library-type index quant
            } elif (eq $args[2] 'sra') {
                put download-accession-list download-run-info-table fastq-dump prefetch
            } elif (eq $args[2] 'ssh') {
                put generate-key
            } elif (eq $args[2] 'star') {
                put align index
            } elif (eq $args[2] 'sys') {
                put linker-info
            } elif (eq $args[2] 'wget') {
                put recursive
            }
        }
    } elif (== $n 5) {
        # Depth 3: app sub-namespace subcommands.
        if (eq $args[1] 'app') {
            if (and (eq $args[2] 'aws') (eq $args[3] 'batch')) {
                put fetch-and-run list-jobs
            } elif (and (eq $args[2] 'aws') (eq $args[3] 'ec2')) {
                put instance-id list-running-instances map-instance-ids-to-names stop
            } elif (and (eq $args[2] 'aws') (eq $args[3] 'ecr')) {
                put login-private login-public
            } elif (and (eq $args[2] 'aws') (eq $args[3] 's3')) {
                put delete-versioned-glacier-objects delete-versioned-objects dot-clean find list-large-files ls mv-to-parent sync sync-git-repo
            } elif (and (eq $args[2] 'bowtie2') (eq $args[3] 'align')) {
                put paired-end
            } elif (and (eq $args[2] 'hisat2') (eq $args[3] 'align')) {
                put paired-end single-end
            } elif (and (eq $args[2] 'kallisto') (eq $args[3] 'quant')) {
                put paired-end single-end
            } elif (and (eq $args[2] 'rsem') (eq $args[3] 'quant')) {
                put bam
            } elif (and (eq $args[2] 'salmon') (eq $args[3] 'quant')) {
                put bam paired-end single-end
            } elif (and (eq $args[2] 'star') (eq $args[3] 'align')) {
                put paired-end single-end
            }
        }
    }
}
