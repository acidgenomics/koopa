#compdef koopa
# Koopa zsh completions.
# @note Updated 2026-05-03.
# @note Auto-generated by 'koopa develop generate-completion'.

_koopa() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- :)--help[Show help]' \
        '(- :)--version[Show version]' \
        '1: :_koopa_cmds' \
        '*:: :->subcmd'
    [[ $state == subcmd ]] || return 0
    case $words[1] in
        app) _koopa_app ;;
        configure) return 0 ;;
        develop) _koopa_develop ;;
        header) return 0 ;;
        install) _koopa_install ;;
        install-all-apps) return 0 ;;
        install-default-apps) return 0 ;;
        internal) return 0 ;;
        list-all-apps) return 0 ;;
        list-default-apps) return 0 ;;
        reinstall) _koopa_install ;;
        system) return 0 ;;
        uninstall) _koopa_install ;;
        update) return 0 ;;
        version) return 0 ;;
    esac
}

_koopa_cmds() {
    local -a cmds
    cmds=(
        'app:Application management'
        'configure:Configure system'
        'develop:Development utilities'
        'header:Print koopa header'
        'install:Install an app'
        'install-all-apps:Install all apps'
        'install-default-apps:Install default apps'
        'internal:Internal utilities'
        'list-all-apps:List all available apps'
        'list-default-apps:List default apps'
        'reinstall:Reinstall an app'
        'system:System operations'
        'uninstall:Uninstall an app'
        'update:Update installed apps'
        'version:Show koopa version'
    )
    _describe -t commands 'koopa command' cmds
}

