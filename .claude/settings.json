{
    "permissions": {
        "allow": [
            "Bash(*)",
            "Edit",
            "Grep",
            "Python(*)",
            "Read"
        ],
        "defaultMode": "plan",
        "deny": [
            "Bash(git add*)",
            "Bash(git commit*)",
            "Bash(git merge*)",
            "Bash(git push*)",
            "Bash(git rebase*)",
            "Bash(git reset*)",
            "Read(.env)"
        ]
    }
}
