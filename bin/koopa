#!/usr/bin/env bash

set -o errexit  # -e
set -o errtrace  # -E
set -o nounset  # -u
set -o pipefail

__koopa_is_installed() { # {{{1
    # """
    # Are all of the requested programs installed?
    # @note Updated 2021-05-07.
    # """
    local cmd
    for cmd in "$@"
    do
        command -v "$cmd" >/dev/null || return 1
    done
    return 0
}

__koopa_is_macos() { # {{{1
    # """
    # Is the operating system macOS?
    # @note Updated 2021-05-07.
    # """
    [[ "$(uname -s)" == 'Darwin' ]]
}

__koopa_print() { # {{{1
    # """
    # Print a string.
    # @note Updated 2021-05-07.
    # """
    local string
    [[ "$#" -gt 0 ]] || return 1
    for string in "$@"
    do
        printf '%b\n' "$string"
    done
    return 0
}

__koopa_realpath() {
    # """
    # Resolve file path.
    # @note Updated 2023-03-23.
    # """
    local arg string
    for arg in "$@"
    do
        string="$( \
            readlink -f "$arg" \
            2>/dev/null \
            || true \
        )"
        if [[ -z "$string" ]]
        then
            string="$( \
                perl -MCwd -le \
                    'print Cwd::abs_path shift' \
                    "$arg" \
                2>/dev/null \
                || true \
            )"
        fi
        if [[ -z "$string" ]]
        then
            string="$( \
                python3 -c \
                    "import os; print(os.path.realpath('${arg}'))" \
                2>/dev/null \
                || true \
            )"
        fi
        [[ -n "$string" ]] || return 1
        __koopa_print "$string"
    done
    return 0
}

__koopa_warn() { # {{{1
    # """
    # Print a warning message to the console.
    # @note Updated 2021-05-14.
    # """
    local string
    [[ "$#" -gt 0 ]] || return 1
    for string in "$@"
    do
        printf '%b\n' "$string" >&2
    done
    return 0
}

main() {
    # """
    # Main koopa CLI function.
    # @note Updated 2025-01-16.
    # """
    # Check for Bash 4+.
    case "${BASH_VERSION:-}" in
        '1.'* | '2.'* | '3.'*)
            __koopa_warn \
                'Bash 4+ is required.' \
                "PATH: ${PATH:-}"
            return 1
            ;;
    esac
    local -A dict
    dict['bash_source']="${BASH_SOURCE[0]}"
    if [[ -L "${dict['bash_source']}" ]]
    then
        dict['bash_source']="$(__koopa_realpath "${dict['bash_source']}")"
    fi
    [[ -x "${dict['bash_source']}" ]] || return 1
    dict['_koopa_prefix']="$( \
        __koopa_realpath "$(dirname "${dict['bash_source']}")/.." \
    )"
    [[ -d "${dict['_koopa_prefix']}" ]] || return 1
    # Dispatch all commands to Python when available.
    dict['python_src']="${dict['_koopa_prefix']}/lang/python/src"
    if [[ -d "${dict['python_src']}" ]]
    then
        dict['python']="${dict['_koopa_prefix']}/opt/python3.14/bin/python3.14"
        if [[ ! -x "${dict['python']}" ]]
        then
            dict['python']="$(command -v python3.14 2>/dev/null || true)"
            if [[ -z "${dict['python']}" ]]
            then
                dict['python']="$(command -v python3 2>/dev/null || true)"
                if [[ -n "${dict['python']}" ]] && \
                    ! "${dict['python']}" -c \
                        'import sys; sys.exit(0 if sys.version_info >= (3, 14) else 1)' \
                        2>/dev/null
                then
                    dict['python']=''
                fi
            fi
        fi
        if [[ -x "${dict['python']}" ]]
        then
            export KOOPA_PREFIX="${dict['_koopa_prefix']}"
            PYTHONPATH="${dict['python_src']}${PYTHONPATH:+:${PYTHONPATH}}" \
                exec "${dict['python']}" -m koopa.cli_main "$@"
        fi
    fi
    # Bash fallback: only used during bootstrap when Python is unavailable.
    dict['header_script']="${dict['_koopa_prefix']}/lang/bash/include/header.sh"
    [[ -f "${dict['header_script']}" ]] || return 1
    export KOOPA_ACTIVATE=0
    export KOOPA_HELP=0
    export KOOPA_PREFIX="${dict['_koopa_prefix']}"
    # shellcheck source=/dev/null
    source "${dict['header_script']}"
    _koopa_cli "$@"
    return 0
}

main "$@"
