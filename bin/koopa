#!/bin/sh
set -eu

__koopa_realpath() {
    _rp_out="$(readlink -f "$1" 2>/dev/null || true)"
    if [ -z "$_rp_out" ]; then
        _rp_out="$( \
            perl -MCwd -le \
                'print Cwd::abs_path shift' \
                "$1" \
            2>/dev/null \
            || true \
        )"
    fi
    if [ -z "$_rp_out" ]; then
        _rp_out="$( \
            python3 -c \
                "import os, sys; print(os.path.realpath(sys.argv[1]))" \
                "$1" \
            2>/dev/null \
            || true \
        )"
    fi
    [ -n "$_rp_out" ] || return 1
    printf '%s\n' "$_rp_out"
}

__koopa_check_python() {
    [ -x "$1" ] && "$1" -c "import bz2, subprocess" 2>/dev/null
}

_koopa_bin="$0"
if [ -L "$_koopa_bin" ]; then
    _koopa_bin="$(__koopa_realpath "$_koopa_bin")"
fi
[ -x "$_koopa_bin" ] || exit 1
_koopa_prefix="$(__koopa_realpath "$(dirname "$_koopa_bin")/..")"
[ -d "$_koopa_prefix" ] || exit 1

_python=""
if [ -n "${KOOPA_BOOTSTRAP_PREFIX:-}" ]; then
    _bootstrap_python="${KOOPA_BOOTSTRAP_PREFIX}/bin/python3"
else
    _bootstrap_python="${_koopa_prefix}-bootstrap/bin/python3"
fi
if __koopa_check_python "$_bootstrap_python"; then
    _python="$_bootstrap_python"
elif [ -x "$_bootstrap_python" ]; then
    printf '%s\n' \
        'Error: koopa bootstrap Python is incomplete.' \
        '' \
        'Run the following to rebuild:' \
        "  sh '${_koopa_prefix}/bootstrap.sh'" \
        >&2
    exit 1
fi
if [ -z "$_python" ]; then
    _sys_python="/usr/bin/python3"
    _required_ver="$(cat "${_koopa_prefix}/.python-version" 2>/dev/null)"
    if [ -n "$_required_ver" ] && [ -x "$_sys_python" ] && \
        "$_sys_python" -c \
            "import sys; sys.exit(0 if sys.argv[1] == '{}.{}'.format(*sys.version_info[:2]) else 1)" \
            "$_required_ver" \
            2>/dev/null && \
        __koopa_check_python "$_sys_python"
    then
        _python="$_sys_python"
    fi
fi
if [ -z "$_python" ]; then
    printf '%s\n' \
        'Error: koopa bootstrap Python not found.' \
        '' \
        'Run the following to bootstrap koopa:' \
        "  sh '${_koopa_prefix}/bootstrap.sh'" \
        >&2
    exit 1
fi

export KOOPA_PREFIX="$_koopa_prefix"
PYTHONPATH="${_koopa_prefix}/lang/python/src${PYTHONPATH:+:${PYTHONPATH}}" \
    exec "$_python" -m koopa.cli_main "$@"
